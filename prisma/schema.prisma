generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String           @unique
  emailVerified  DateTime?
  image          String?
  role           String           @default("user")
  accounts       Account[]
  sessions       Session[]
  votes          Vote[]
  comments       Comment[]
  submissions    Idea[]           @relation("SubmittedIdeas")
  analyses       Analysis[]
  generationRuns GenerationRun[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("ib_users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("ib_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ib_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("ib_verification_tokens")
}

model Idea {
  id           Int       @id @default(autoincrement())
  name         String
  slug         String    @unique
  tagline      String
  description  String    @db.Text
  category     String
  status       String
  targetMarket String
  tam          String
  pricing      String
  stack        String[]
  effort       String
  revenueModel String
  tags         String[]
  parentId     Int?
  parent       Idea?     @relation("IdeaVariations", fields: [parentId], references: [id])
  children     Idea[]    @relation("IdeaVariations")
  aiGenerated  Boolean   @default(false)
  submittedBy  String?
  submitter    User?     @relation("SubmittedIdeas", fields: [submittedBy], references: [id])
  votes        Vote[]
  comments     Comment[]
  analyses     Analysis[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("ib_ideas")
}

model Analysis {
  id              String   @id @default(cuid())
  ideaId          Int
  idea            Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  requestedBy     String?
  user            User?    @relation(fields: [requestedBy], references: [id])
  marketAnalysis  String   @db.Text
  competitors     String   @db.Text
  revenueProjection String @db.Text
  implementationPlan String @db.Text
  swotAnalysis    String   @db.Text
  score           Int      @default(0)
  model           String   @default("claude")
  createdAt       DateTime @default(now())

  @@index([ideaId])
  @@map("ib_analyses")
}

model Vote {
  id     String @id @default(cuid())
  ideaId Int
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  value  Int    @default(1)

  @@unique([ideaId, userId])
  @@map("ib_votes")
}

model Comment {
  id        String   @id @default(cuid())
  ideaId    Int
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([ideaId])
  @@map("ib_comments")
}

model GenerationRun {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  market         String
  niche          String?
  audience       String?
  category       String?
  count          Int
  ideasGenerated Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("ib_generation_runs")
}
